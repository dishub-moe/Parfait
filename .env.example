# Base URL of this Parfait instance (used for WebSub callback URL generation)
BASE_URL=https://example.com

# Path under BASE_URL that receives WebSub push callbacks
CALLBACK_PATH=/webhub/callback

# YouTube Data API v3 key (https://console.cloud.google.com/)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Redis connection URL for the Queues job queue
REDIS_URL=redis://localhost:6379

# MySQL database connection
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USERNAME=parfait_user
DATABASE_PASSWORD=change_me
DATABASE_NAME=parfait_db

# Set to any value to notify each video only once (skip if already in DB)
# ONLY_NOTIFY_ONCE=1
